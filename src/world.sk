command /listworlds:
	permission: op
	trigger:
		send "There are %size of {worldArray::*}%/%{maxWorlds}% world's. Currently there are %{genServerWorldAmount}% worlds on the gen server" to player
		loop {worldArray::*}:
			send "%loop-index% %loop-value%" to player

command /test:
	trigger:
		delete {inGame::*}